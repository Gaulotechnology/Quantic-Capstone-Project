# ============================================================
# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit secrets.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=tumaini
POSTGRES_PASSWORD=tumaini_dev

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── Qdrant ───────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AWS S3 (af-south-1 for POPIA compliance) ─────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=af-south-1
S3_BUCKET_NAME=tumaini-cvs-dev

# ── LLM ──────────────────────────────────────────────────────
# DeepSeek (primary) — OpenAI-compatible API
# Get your key at https://platform.deepseek.com
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
# Local Llama 3 via Ollama (fallback, no key required)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Service-to-service URLs (internal Docker network) ────────
IDENTITY_SERVICE_URL=http://identity:8000
CV_SERVICE_URL=http://cv:8000
VECTOR_SERVICE_URL=http://vector:8000
MATCHING_SERVICE_URL=http://matching:8000
JOB_SERVICE_URL=http://job:8000
